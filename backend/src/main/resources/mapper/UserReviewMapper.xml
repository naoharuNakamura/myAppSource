<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.backend.mapper.UserReviewMapper">

    <sql id="tablename">t_user_review_history</sql>

    <resultMap id="UserReviewResultMap" type="com.example.backend.model.UserReview">
        <id property="reviewId" column="review_id" />
        <result property="userId" column="user_id" />
        <result property="restaurantId" column="restaurant_id" />
        <result property="userRating" column="user_rating" />
        <result property="userMemo" column="user_memo" />
        <result property="createdAt" column="created_at" />
    </resultMap>

    <select id="findByRestaurantId" resultMap="UserReviewResultMap"> 
        SELECT *
        FROM <include refid="tablename"/> 
        WHERE restaurant_id = #{restaurantId}
        ORDER BY created_at DESC
    </select>

    <select id="findByReviewId" resultMap="UserReviewResultMap">
        SELECT user_id
        FROM <include refid="tablename"/> 
        WHERE review_id = #{reviewId}
    </select>
    
    <insert id="insertReview" parameterType="com.example.backend.model.UserReview">
        INSERT INTO <include refid="tablename" /> 
        (user_id, restaurant_id, user_rating, user_memo) 
        VALUES (#{userId}, #{restaurantId}, #{userRating}, #{userMemo})
    </insert>

    <select id="caluclateAverageRating" resultType="double">
        SELECT AVG(user_rating)
        FROM <include refid="tablename"/>
        WHERE restaurant_id = #{restaurantId}
        GROUP BY restaurant_id 
    </select>

    <delete id="deleteByReviewIdByUserId"> 
        DELETE FROM <include refid="tablename" /> 
        WHERE review_id = #{reviewId}
        AND user_id = #{userId}
    </delete>

</mapper>